{
  "name": "signalen_frontend_poc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rimraf .next/ tmp/",
    "dev": "concurrently -k -n app,tokens \"npm:dev:next\" \"npm:tokens:watch:org\"",
    "dev:next": "next dev",
    "build": "npm run tokens:build:org && next build",
    "install-test-browsers": "playwright install --with-deps",
    "start": "next start",
    "start:test-e2e": "node .next/standalone/server.js",
    "lint": "eslint .",
    "test": "vitest",
    "test-e2e": "playwright test test/e2e/",
    "update-patch": "npm-check-updates --configFileName .ncurc.patch.cjs",
    "update-minor": "npm-check-updates --configFileName .ncurc.minor.cjs",
    "update-major": "npm-check-updates --configFileName .ncurc.major.cjs",
    "update-design-system": "npm-check-updates --configFileName .ncurc.major.cjs --filter '/^@(utrecht|nl-design-system-community)/'",
    "tokens:build": "node ./design-tokens/build-theme.mjs",
    "tokens:build:org": "node ./design-tokens/build-theme.mjs --org",
    "tokens:watch:org": "chokidar \"design-tokens/base.json\" \"design-tokens/overrides.json\" \"design-tokens/organizations/*.json\" --initial --polling -d 500 -c \"node ./design-tokens/watch-build-org.mjs {path}\""
  },
  "dependencies": {
    "@headlessui/react": "2.2.4",
    "@hookform/resolvers": "3.9.0",
    "@nl-design-system-candidate/button-css": "1.1.0",
    "@nl-design-system-candidate/button-react": "1.1.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-visually-hidden": "1.1.1",
    "@tabler/icons-react": "3.36.1",
    "@turf/turf": "7.3.3",
    "@utrecht/checkbox-group-react": "1.0.14",
    "@utrecht/component-library-css": "7.2.0",
    "@utrecht/component-library-react": "10.2.2",
    "@utrecht/design-tokens": "3.4.1",
    "@utrecht/fieldset-react": "1.0.10",
    "@utrecht/form-field-description-react": "1.0.10",
    "@utrecht/form-field-error-message-react": "1.0.10",
    "@utrecht/form-field-react": "1.0.10",
    "@utrecht/form-label-react": "1.0.10",
    "@utrecht/link-list-css": "3.0.1",
    "@utrecht/link-react": "1.0.10",
    "@utrecht/nav-bar-react": "1.0.6",
    "@utrecht/page-body-react": "1.0.6",
    "@utrecht/page-footer-react": "1.0.6",
    "@utrecht/page-header-react": "1.0.6",
    "@utrecht/page-layout-react": "1.0.6",
    "@utrecht/radio-button-react": "1.0.10",
    "@utrecht/radio-group-react": "1.0.10",
    "@utrecht/root-react": "1.0.16",
    "@utrecht/select-combobox-react": "1.0.10",
    "axios": "1.13.2",
    "axios-retry": "4.5.0",
    "class-variance-authority": "0.7.1",
    "dompurify": "3.4.5",
    "form-data": "4.0.5",
    "immer": "10.1.1",
    "maplibre-gl": "4.7.1",
    "next": "16.1.1",
    "next-intl": "4.6.1",
    "react": "18",
    "react-dom": "18",
    "react-hook-form": "7.69.0",
    "react-map-gl": "8.0.4",
    "react-markdown": "9.0.1",
    "sharp": "0.33.5",
    "tailwind-merge": "2.6.0",
    "usehooks-ts": "3.1.1",
    "validator": "13.15.26",
    "vaul": "1.1.2",
    "zod": "3.23.8",
    "zustand": "5.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@nl-design-system-community/purmerend-design-tokens": "1.2.3",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/node": "24",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@types/validator": "13.12.2",
    "@vitejs/plugin-react": "5.1.1",
    "autoprefixer": "10.4.20",
    "chokidar-cli": "3.0.0",
    "concurrently": "9.2.1",
    "eslint": "9",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.5.4",
    "jsdom": "25.0.1",
    "npm-check-updates": "19.1.1",
    "postcss": "8",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "style-dictionary": "4.4.0",
    "tailwindcss": "3.4.14",
    "typescript": "5",
    "vitest": "3.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.29.2"
  }
}
